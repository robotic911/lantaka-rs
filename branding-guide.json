{
  "brandingGuide": {
    "version": "1.0",
    "lastUpdated": "2026-04-07",
    "project": "Project Name",
    "overview": {
      "description": "Comprehensive branding guidelines for consistent visual identity across all platforms and materials",
      "purpose": "Ensure consistency in color, typography, and styling across all brand touchpoints"
    },
    "colorPalette": {
      "primary": {
        "name": "Ocean Blue",
        "hex": "#0066CC",
        "rgb": "rgb(0, 102, 204)",
        "usage": "Primary buttons, headers, key brand elements",
        "accessibility": "WCAG AA compliant for text"
      },
      "secondary": {
        "name": "Coral Red",
        "hex": "#FF6B57",
        "rgb": "rgb(255, 107, 87)",
        "usage": "Call-to-action buttons, highlights, accents",
        "accessibility": "WCAG AA compliant for text on light backgrounds"
      },
      "accent": {
        "name": "Gold",
        "hex": "#FFB800",
        "rgb": "rgb(255, 184, 0)",
        "usage": "Icons, badges, premium features",
        "accessibility": "Use with dark text for contrast"
      },
      "neutral": {
        "light": {
          "name": "Off-White",
          "hex": "#F8F9FA",
          "rgb": "rgb(248, 249, 250)",
          "usage": "Backgrounds, light surfaces"
        },
        "medium": {
          "name": "Light Gray",
          "hex": "#E8EAED",
          "rgb": "rgb(232, 234, 237)",
          "usage": "Borders, dividers, disabled states"
        },
        "dark": {
          "name": "Charcoal",
          "hex": "#333333",
          "rgb": "rgb(51, 51, 51)",
          "usage": "Body text, dark backgrounds"
        }
      },
      "semantic": {
        "success": {
          "name": "Green",
          "hex": "#4CAF50",
          "rgb": "rgb(76, 175, 80)",
          "usage": "Success messages, confirmations, positive actions"
        },
        "warning": {
          "name": "Amber",
          "hex": "#FFC107",
          "rgb": "rgb(255, 193, 7)",
          "usage": "Warning messages, alerts, caution states"
        },
        "error": {
          "name": "Red",
          "hex": "#F44336",
          "rgb": "rgb(244, 67, 54)",
          "usage": "Error messages, destructive actions, alerts"
        },
        "info": {
          "name": "Sky Blue",
          "hex": "#2196F3",
          "rgb": "rgb(33, 150, 243)",
          "usage": "Information messages, tips, help content"
        }
      }
    },
    "typography": {
      "fontFamily": {
        "primary": {
          "name": "Inter",
          "fallback": "Segoe UI, Roboto, sans-serif",
          "type": "Sans-serif",
          "usage": "Body text, UI elements, general content",
          "googleFonts": "https://fonts.google.com/specimen/Inter"
        },
        "secondary": {
          "name": "Poppins",
          "fallback": "Trebuchet MS, sans-serif",
          "type": "Sans-serif",
          "usage": "Headings, display text, emphasis",
          "googleFonts": "https://fonts.google.com/specimen/Poppins"
        },
        "monospace": {
          "name": "Fira Code",
          "fallback": "Courier New, monospace",
          "type": "Monospace",
          "usage": "Code blocks, technical content, data displays",
          "googleFonts": "https://fonts.google.com/specimen/Fira+Code"
        }
      },
      "scales": {
        "h1": {
          "fontFamily": "Poppins",
          "fontSize": "2.5rem",
          "fontWeight": 700,
          "lineHeight": 1.2,
          "letterSpacing": "-0.02em",
          "usage": "Main page headings, hero titles"
        },
        "h2": {
          "fontFamily": "Poppins",
          "fontSize": "2rem",
          "fontWeight": 700,
          "lineHeight": 1.3,
          "letterSpacing": "-0.01em",
          "usage": "Section headings"
        },
        "h3": {
          "fontFamily": "Poppins",
          "fontSize": "1.5rem",
          "fontWeight": 600,
          "lineHeight": 1.4,
          "letterSpacing": "0em",
          "usage": "Subsection headings"
        },
        "h4": {
          "fontFamily": "Poppins",
          "fontSize": "1.25rem",
          "fontWeight": 600,
          "lineHeight": 1.4,
          "usage": "Smaller headings, card titles"
        },
        "body": {
          "fontFamily": "Inter",
          "fontSize": "1rem",
          "fontWeight": 400,
          "lineHeight": 1.6,
          "letterSpacing": "0em",
          "usage": "Main body text, paragraphs"
        },
        "bodySmall": {
          "fontFamily": "Inter",
          "fontSize": "0.875rem",
          "fontWeight": 400,
          "lineHeight": 1.5,
          "usage": "Secondary text, captions, metadata"
        },
        "button": {
          "fontFamily": "Inter",
          "fontSize": "1rem",
          "fontWeight": 600,
          "lineHeight": 1.5,
          "letterSpacing": "0.02em",
          "textTransform": "none",
          "usage": "Button text"
        }
      }
    },
    "styling": {
      "spacing": {
        "description": "Base spacing unit: 8px. All spacing uses multiples of 8px for consistency",
        "xs": "4px",
        "sm": "8px",
        "md": "16px",
        "lg": "24px",
        "xl": "32px",
        "xxl": "48px"
      },
      "borderRadius": {
        "none": "0px",
        "sm": "4px",
        "md": "8px",
        "lg": "12px",
        "full": "9999px",
        "usage": "sm for small elements, md for most UI, lg for large containers, full for pills"
      },
      "shadows": {
        "none": "none",
        "sm": {
          "value": "0 1px 2px rgba(0, 0, 0, 0.05)",
          "usage": "Subtle elevation for cards"
        },
        "md": {
          "value": "0 4px 6px rgba(0, 0, 0, 0.1)",
          "usage": "Standard elevation for modals, dropdowns"
        },
        "lg": {
          "value": "0 10px 15px rgba(0, 0, 0, 0.15)",
          "usage": "High elevation for overlays, floating elements"
        },
        "xl": {
          "value": "0 20px 25px rgba(0, 0, 0, 0.2)",
          "usage": "Maximum elevation for dialogs"
        }
      },
      "buttons": {
        "primary": {
          "backgroundColor": "#0066CC",
          "color": "#FFFFFF",
          "padding": "12px 24px",
          "borderRadius": "8px",
          "fontSize": "1rem",
          "fontWeight": 600,
          "border": "none",
          "cursor": "pointer",
          "transition": "all 0.3s ease",
          "hoverState": {
            "backgroundColor": "#0052A3",
            "boxShadow": "0 4px 6px rgba(0, 102, 204, 0.3)"
          },
          "activeState": {
            "backgroundColor": "#003D7A"
          },
          "disabledState": {
            "backgroundColor": "#E8EAED",
            "color": "#999999",
            "cursor": "not-allowed"
          }
        },
        "secondary": {
          "backgroundColor": "transparent",
          "color": "#0066CC",
          "padding": "12px 24px",
          "borderRadius": "8px",
          "fontSize": "1rem",
          "fontWeight": 600,
          "border": "2px solid #0066CC",
          "cursor": "pointer",
          "transition": "all 0.3s ease",
          "hoverState": {
            "backgroundColor": "#F0F5FF",
            "borderColor": "#0052A3"
          },
          "activeState": {
            "backgroundColor": "#E8EEFF"
          }
        },
        "danger": {
          "backgroundColor": "#F44336",
          "color": "#FFFFFF",
          "padding": "12px 24px",
          "borderRadius": "8px",
          "fontSize": "1rem",
          "fontWeight": 600,
          "border": "none",
          "cursor": "pointer",
          "hoverState": {
            "backgroundColor": "#D32F2F"
          }
        }
      },
      "forms": {
        "inputField": {
          "padding": "12px 16px",
          "borderRadius": "8px",
          "border": "1px solid #E8EAED",
          "fontSize": "1rem",
          "fontFamily": "Inter",
          "backgroundColor": "#FFFFFF",
          "focusState": {
            "borderColor": "#0066CC",
            "boxShadow": "0 0 0 3px rgba(0, 102, 204, 0.1)",
            "outline": "none"
          },
          "errorState": {
            "borderColor": "#F44336",
            "boxShadow": "0 0 0 3px rgba(244, 67, 54, 0.1)"
          },
          "disabledState": {
            "backgroundColor": "#F8F9FA",
            "color": "#999999",
            "cursor": "not-allowed"
          }
        },
        "label": {
          "fontSize": "0.875rem",
          "fontWeight": 600,
          "color": "#333333",
          "marginBottom": "8px",
          "display": "block"
        },
        "helperText": {
          "fontSize": "0.75rem",
          "color": "#666666",
          "marginTop": "4px"
        }
      },
      "cards": {
        "padding": "24px",
        "borderRadius": "12px",
        "backgroundColor": "#FFFFFF",
        "border": "1px solid #E8EAED",
        "boxShadow": "0 1px 2px rgba(0, 0, 0, 0.05)",
        "hoverState": {
          "boxShadow": "0 4px 6px rgba(0, 0, 0, 0.1)"
        }
      },
      "transitions": {
        "fast": "0.15s ease",
        "normal": "0.3s ease",
        "slow": "0.5s ease",
        "properties": "Use for color, background-color, box-shadow, border-color"
      }
    },
    "guidelines": {
      "colorUsage": {
        "primaryColor": "Use for main CTAs, primary navigation, key brand elements",
        "secondaryColor": "Use for secondary CTAs, highlights, emphasis",
        "accentColor": "Use sparingly for icons, badges, premium indicators",
        "semanticColors": "Always use semantic colors for status indicators (success, error, warning, info)",
        "contrast": "All text must have minimum 4.5:1 contrast ratio (WCAG AA) for accessibility"
      },
      "typography": {
        "hierarchy": "Use the defined scale consistently to create visual hierarchy",
        "lineLength": "Keep body text between 50-75 characters per line for readability",
        "spacing": "Use defined spacing scale for margins and padding",
        "fontWeights": "Only use 400 (regular) and 600/700 (bold) weights to minimize font files"
      },
      "spacing": {
        "consistency": "Always use multiples of 8px spacing unit",
        "margins": "Use lg (24px) for section separation, md (16px) for component spacing",
        "padding": "Use md (16px) for most containers, lg (24px) for large sections"
      },
      "interactions": {
        "hoverStates": "All interactive elements must have visible hover states",
        "focusStates": "All interactive elements must have visible focus states for keyboard navigation",
        "activeStates": "Provide visual feedback for active/pressed states",
        "transitionTime": "Use 0.3s ease for all transitions to feel responsive"
      }
    },
    "examples": {
      "colorCombinations": {
        "primary_neutral": {
          "primary": "#0066CC",
          "neutral": "#F8F9FA",
          "usage": "Main app background with primary accent"
        },
        "secondary_dark": {
          "secondary": "#FF6B57",
          "dark": "#333333",
          "usage": "High contrast CTAs"
        },
        "accent_primary": {
          "accent": "#FFB800",
          "primary": "#0066CC",
          "usage": "Premium features on blue backgrounds"
        }
      },
      "typoExamples": {
        "heroSection": "H1 Poppins Bold + Body Inter Regular on neutral background",
        "cardTitle": "H4 Poppins SemiBold with md shadow + body text",
        "formLabel": "Label Inter SemiBold (0.875rem) + Input field Inter Regular"
      }
    }
  }
}
