# Version control
.git
.gitignore
.gitattributes

# Dependencies (rebuilt inside Docker)
vendor/
node_modules/

# Local environment — NEVER bake secrets into the image
.env
.env.*
!.env.example

# Dev / test artifacts
storage/logs/*.log
storage/framework/cache/*
storage/framework/sessions/*
storage/framework/views/*
bootstrap/cache/*.php

# Build tools

.dockerignore

# Editor / OS noise
.idea/
.vscode/
*.DS_Store
Thumbs.db

# CI
.github/
.gitlab-ci.yml

# Local docs / extras
README.md
*.html
supabase/
tests/

# npm build output (Vite) — keep public/build if pre-built,
# otherwise remove this comment and add public/build/
